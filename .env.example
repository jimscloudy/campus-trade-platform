# 复制为 server/.env

PORT=3000
JWT_SECRET=campus-trade-jwt-secret-change-me
JWT_EXPIRES=7d

# MySQL（本地默认 127.0.0.1；Docker 线上用 host=mysql）
DB_TYPE=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=campus
DB_PASSWORD=campus123
DB_NAME=campus_trade

# AI（可选，也可后台配置）
AI_API_KEY=
AI_BASE_URL=https://api.hualong.online/v1
AI_MODEL=grok-4.5
AI_MODEL_STRONG=grok-4.5
