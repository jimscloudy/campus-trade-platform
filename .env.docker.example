# 复制为 .env.docker 后填写真实值：
#   cp .env.docker.example .env.docker
#
# 注意：.env.docker 不要提交到 git

JWT_SECRET=please-change-this-to-a-long-random-string
JWT_EXPIRES=7d
WEB_PORT=8081
API_PORT=3001

# Grok 通道（默认）
AI_API_KEY=sk-你的grok密钥
AI_BASE_URL=https://api.hualong.online/v1
AI_MODEL=grok-4.5
AI_MODEL_STRONG=grok-4.5

# OpenAI 通道（后台可切换）
AI_API_KEY_OPENAI=sk-你的openai密钥
AI_BASE_URL_OPENAI=https://api.hualong.online/v1
AI_MODEL_OPENAI=gpt-5.4-mini
AI_MODEL_OPENAI_STRONG=gpt-5.4
