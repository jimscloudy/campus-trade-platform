# 复制为 .env.docker 后填写：
#   cp .env.docker.example .env.docker

JWT_SECRET=please-change-this-to-a-long-random-string
JWT_EXPIRES=7d
WEB_PORT=8081
API_PORT=3001

# MySQL（Docker 内网）
DB_TYPE=mysql
DB_HOST=mysql
DB_PORT=3306
DB_USER=campus
DB_PASSWORD=campus123
DB_NAME=campus_trade
MYSQL_ROOT_PASSWORD=root123456
# 宿主机连接端口（Navicat 等用）
MYSQL_PORT=3307

# AI（也可在管理后台配置）
AI_API_KEY=
AI_BASE_URL=https://api.hualong.online/v1
AI_MODEL=grok-4.5
AI_MODEL_STRONG=grok-4.5
AI_API_KEY_OPENAI=
AI_MODEL_OPENAI=gpt-5.4-mini
AI_MODEL_OPENAI_STRONG=gpt-5.4
